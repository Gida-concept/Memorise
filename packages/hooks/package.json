{
  "name": "@gida-concept/pm-agent-hooks",
  "version": "0.2.2",
  "description": "PM Agent Claude Code hooks — enforce rules at the client level across all tool calls",
  "files": [
    "src/*.mjs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
