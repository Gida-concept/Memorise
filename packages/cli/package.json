{
  "name": "@gida-concept/pm-agent-cli",
  "version": "0.2.5",
  "description": "PM Agent CLI — terminal interface for project memory and rules",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pm": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@gida-concept/pm-agent-core": "^0.2.5",
    "@gida-concept/pm-agent-hooks": "^0.2.5",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "inquirer": "^10.0.0",
    "@types/inquirer": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.2.0",
    "@types/node": "^20.0.0"
  }
}
