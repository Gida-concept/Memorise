{
  "name": "@gida-concept/pm-agent-core",
  "version": "0.1.2",
  "description": "PM Agent core — memory layer, rules engine, and codebase intelligence",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "toml": "^3.0.0",
    "glob": "^11.0.0",
    "minimatch": "^10.0.0",
    "ignore": "^6.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.5.0",
    "tsup": "^8.2.0"
  }
}
